#!/usr/bin/env sh
# ─────────────────────────────────────────────────────────────────────────────
# ANTI-GRAVITY GUARDRAIL — Pre-commit Hook
# Blocks commits that violate:
#   1. ESLint rules (inline styles, architectural boundaries, React hooks)
#   2. TypeScript type errors
#   3. Architectural layer violations (dependency-cruiser)
# ─────────────────────────────────────────────────────────────────────────────

echo "🛡️  Anti-Gravity Guardrails: Running pre-commit checks..."

# Run lint-staged (ESLint + tsc on staged files)
npx lint-staged

if [ $? -ne 0 ]; then
  echo ""
  echo "❌ COMMIT BLOCKED: ESLint or TypeScript errors found."
  echo "   Fix the issues above before committing."
  echo "   Run 'pnpm lint' to see all violations."
  exit 1
fi

# Run architectural dependency check on the whole project
npx depcruise --config .dependency-cruiser.cjs app components lib --output-type err-long

if [ $? -ne 0 ]; then
  echo ""
  echo "❌ COMMIT BLOCKED: Architectural boundary violation detected."
  echo "   Run 'pnpm lint:arch' to see the full report."
  exit 1
fi

echo ""
echo "✅ All guardrails passed. Commit proceeding."
